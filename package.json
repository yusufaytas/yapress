{
  "name": "@yusufaytas/yapress",
  "version": "0.3.0",
  "description": "A modern, content-first blogging platform built with Next.js and MDX.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yusufaytas/yapress.git"
  },
  "keywords": [
    "yapress",
    "blog",
    "nextjs",
    "mdx",
    "markdown",
    "cms",
    "static-site"
  ],
  "author": "Yusuf Aytas",
  "license": "Apache License",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/clean-build.mjs && node scripts/validate-content.mjs && node scripts/generate-rss.mjs && next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "validate:content": "node scripts/validate-content.mjs",
    "import:wordpress": "node scripts/import-wordpress.mjs",
    "enable-plugin": "node scripts/enable-plugin.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^15.3.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reading-time": "^1.5.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.6",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "turndown": "^7.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "xml2js": "^0.6.2"
  }
}
